{% extends 'base.html.twig' %}

{% block title %}Mon panier{% endblock %}

{% block body %}




        <div>
                <div class="card col-md-12">
                    <div class="card-header">
                        <a class="btn-back text-secondary" href='{{ path('app_boutique_index') }}'>
                            <i class="fas fa-2x fa-arrow-circle-left"></i>
                        </a>
                        <h3>
                            {% set nbProduits = render(controller(
                                'App\\Controller\\PanierController::nombreProduits'
                            )) %}

                            <i class="fas fa-shopping-cart"></i>

                            <span class="badge badge-pill badge-info">{{ nbProduits }}</span>
                            produit(s) - montant :
                            <b> {{ total }}</b>
                        </h3>
                    </div>
                        <div class="card-body">

                    {% if panier| length ==0 %}
                        <p>Ton panier est vide !</p>
                        <p>Voudrais-tu briser notre petit cœur fragile de commerçant ?</p>
                        <i class="fas fa-2x fa-heart-broken text-danger text-blink"></i>
                    {% else%}
                        {% if is_granted("ROLE_CLIENT") %}
                            <a class="btn btn-primary" href="{{ path('app_panier_commander') }}">
                                Passer la commande
                            </a>

                        {% endif %}
                            <table class="table table-striped table-sm table-hover">
                                <thead>
                                <tr>
                                    <th></th>
                                    <th>Produit</th>
                                    <th>Prix</th>
                                    <th>Quantité</th>
                                    <th>Total</th>
                                    <th>Supprimer</th>
                                </tr>
                                </thead>
                                {% for item in panier %}
                                    <tr>

                                        <td>
                                            <img src="{{ item.produit.getVisuel() }}" alt="{{ item.produit.getLibelle() }}">
                                        </td>
                                        <td>{{ item.produit.getLibelle() }}</td>
                                        <td>{{ item.produit.getPrix() }}</td>
                                        <td>
                                            <a href="{{ path('app_panier_enlever', {
                                                idProduit: item.produit.id,
                                                quantite: 1
                                            }) }}">
                                                <i class="fas fa-minus"></i>
                                            </a>

                                            {{ item.quantite }}

                                            <a href="{{ path('app_panier_ajouter', {
                                                idProduit: item.produit.id,
                                                quantite: 1
                                            }) }}">
                                                <i class="fas fa-plus"></i>
                                            </a>
                                        </td>
                                        <td>{{ item.produit.getPrix() * item.quantite }}</td>
                                        <td>
                                            <a href="{{ path('app_panier_supprimer', {
                                                idProduit: item.produit.id
                                            }) }}">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% endfor %}
                                <tfoot>
                                <tr>
                                    <th class="text-right" colspan="4">
                                        Total
                                    </th>
                                    <th>
                                        {{ total }}
                                    </th>
                                    <th>
                                        <a href="{{ path('app_panier_vider', {
                                            _locale: app.request.locale
                                        }) }}">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </th>
                                </tr>
                                </tfoot>
                            </table>
                        </div>
                    {% endif %}
                </div>









        </div>


    <hr>



{% endblock %}
