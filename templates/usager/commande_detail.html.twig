{% extends 'base.html.twig' %}

{% block title %}Detail de la commande{% endblock %}

{% block body %}
    <h1>Détail de la commande n°{{ commande.id }}</h1>

    <p>Date : {{ commande.dateCreation|date('d/m/Y H:i') }}</p>

    <ul>
        {% for ligne in commande.getLigneCommandes() %}
            <li>
                {{ ligne.getProduit().getLibelle() }} —
                {{ ligne.getQuantite() }} × {{ ligne.getPrix() }} €
            </li>
        {% endfor %}
    </ul>
{% endblock %}
